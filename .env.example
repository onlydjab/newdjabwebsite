# Copy this file to .env (same folder) and fill in real values.
# .env is gitignored and never committed — safe to put real secrets here.

# Gmail App Password used to send booking-inquiry emails.
# Create one at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification enabled on the Gmail account).
EMAIL_APP_PASSWORD=

# Login for the local /dashboard admin panel (HTTP Basic Auth).
# The dashboard refuses all requests until DASHBOARD_PASSWORD is set.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=
